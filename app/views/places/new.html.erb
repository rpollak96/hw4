<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card shadow-sm mt-5">
      <div class="card-body p-4">
        <h1 class="card-title text-center mb-4 text-primary">New Place</h1>

        <form action="/places" method="post">
          <div class="mb-3">
            <label for="name_input" class="form-label text-secondary">Place Name</label>
            <input type="text" name="name" id="name_input" class="form-control" placeholder="e.g. Chicago, Tokyo, London">
          </div>

          <div class="d-grid mt-4">
            <button class="btn btn-primary btn-lg">Save Place</button>
          </div>
        </form>
        
        <div class="mt-3 text-center">
          <a href="/places" class="btn btn-link">Back to All Places</a>
        </div>
      </div>
    </div>
  </div>
</div>
