<div class="row align-items-center mb-4 mt-4">
  <div class="col">
    <h1 class="display-5 text-primary"><%= @place["name"] %></h1>
  </div>
  <% if @current_user %>
    <div class="col-auto">
      <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-success">
        <i class="bi bi-journal-plus"></i> New Entry
      </a>
    </div>
  <% end %>
</div>

<h2 class="h4 text-secondary mb-4">My Memories</h2>

<% if @entries.any? %>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% for entry in @entries %>
      <div class="col">
        <div class="card h-100 shadow-sm border-0">
          <% if entry.uploaded_image.attached? %>
            <%= image_tag entry.uploaded_image, class: "card-img-top" %>
          <% end %>
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h3 class="h5 card-title mb-0"><%= entry["title"] %></h3>
              <span class="badge bg-light text-dark shadow-sm">
                <i class="bi bi-calendar-event me-1"></i><%= entry["occurred_on"] %>
              </span>
            </div>
            <p class="card-text text-muted"><%= entry["description"] %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="alert alert-light border text-center p-5">
    <p class="mb-0 text-muted">No memories recorded for this place yet.</p>
  </div>
<% end %>

<div class="mt-5 mb-5 border-top pt-4">
  <a href="/places" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left"></i> Back to All Places
  </a>
</div>
